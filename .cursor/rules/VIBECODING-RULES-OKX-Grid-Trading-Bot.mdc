## 🧪 TESTING

```python
# Mockear ccxt siempre en unit tests
from unittest.mock import MagicMock

def test_calcula_niveles_correctamente():
    calc = GridCalculator(price_min=80000, price_max=90000, num_levels=5)
    levels = calc.calculate()
    assert levels == [80000, 82500, 85000, 87500, 90000]

def test_dry_run_no_llama_al_exchange():
    mock_exchange = MagicMock()
    client = OKXClient(exchange=mock_exchange, dry_run=True)
    client.place_order("BTC/USDT", "buy", 85000, 0.001)
    mock_exchange.create_limit_buy_order.assert_not_called()
```

